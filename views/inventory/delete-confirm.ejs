<h1><%= title %></h1>
<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
<p><strong>Confirm Deletion</strong> - This action cannot be undone.</p>
<div id="delete-inventory-form">
  <form action="/inv/delete" method="post">
    <label for="inv_make">Make:</label>
    <input type="text" id="inv_make" name="inv_make" readonly value="<%= locals.inv_make %>">

    <label for="inv_model">Model:</label>
    <input type="text" id="inv_model" name="inv_model" readonly value="<%= locals.inv_model %>">

    <label for="inv_year">Year:</label>
    <input type="text" id="inv_year" name="inv_year" readonly value="<%= locals.inv_year %>">

    <label for="inv_price">Price:</label>
    <input type="text" id="inv_price" name="inv_price" readonly value="$<%= Number(locals.inv_price).toLocaleString() %>">

    <input type="hidden" name="inv_id" value="<%= locals.inv_id %>">

    <button type="submit">Confirm Delete</button>
  </form>
</div>
